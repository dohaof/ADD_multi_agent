<?xml version="1.0" encoding="UTF-8"?>
<!--
  Project-local Maven settings.

  The global ~/.m2/settings.xml on this machine mirrors Maven Central over
  http://, which Maven 3.9+ refuses to use (maven-default-http-blocker).
  This file overrides that with an https Aliyun mirror so the Spring AI
  Alibaba dependencies can be downloaded.

  Use it explicitly:
      mvn -s .mvn/settings.xml clean compile
  (run.sh already passes this flag.)
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0
                              https://maven.apache.org/xsd/settings-1.0.0.xsd">
    <mirrors>
        <mirror>
            <id>aliyun-https</id>
            <name>Aliyun Public Mirror (https)</name>
            <url>https://maven.aliyun.com/repository/public</url>
            <mirrorOf>central</mirrorOf>
        </mirror>
    </mirrors>
</settings>
